# =============================================================================
# CRONO — Environment template (safe to commit)
# =============================================================================
# JOB: single source of env vars for all workspaces (db, backend, worker)
# SETUP: cp .env.example .env  →  edit .env with real secrets (never commit .env)
# WHO USES THIS:
#   packages/db      → DATABASE_URL (migrate, prisma client)
#   packages/queue   → REDIS_URL
#   apps/backend     → all vars below (Phase 4+)
#   apps/worker      → REDIS_URL + DATABASE_URL (Phase 8+)
# COMMON MISTAKES:
#   - Port 5432 in DATABASE_URL — docker-compose maps Postgres to host 5433
#   - Per-app .env files — use repo root .env only (packages load ../../.env)
# VERIFY: docker compose up -d && npm run db:migrate -w @crono/db
# =============================================================================

# --- Phase 1: packages/db (required) ---
DATABASE_URL=postgresql://postgres:password@localhost:5433/crono

# --- Phase 2: packages/queue (required) ---
REDIS_URL=redis://localhost:6379

# --- Phase 4: apps/backend scaffold (required from Phase 4) ---
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000

# --- Phase 5: auth (required once env.ts validates JWT — add before Phase 5) ---
JWT_SECRET=replace_with_random_64_char_string_min_32_bytes

# --- Phase 10: failure emails ---
# RESEND_API_KEY=re_...

# --- Phase 11: Stripe billing ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_STARTER_PRICE_ID=price_...
# STRIPE_PRO_PRICE_ID=price_...

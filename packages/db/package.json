{
  "name": "@crono/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "db:generate": "prisma generate",
    "db:migrate": "node --env-file=../../.env ../../node_modules/.bin/prisma migrate dev",
    "db:studio": "node --env-file=../../.env ../../node_modules/.bin/prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "prisma": "^6.9.0",
    "typescript": "^5.6.3"
  }
}
